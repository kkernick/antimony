# Make sure the command actually functions
assert $ANTIMONY edit --help

# Try and create a new profile using valid definitions
for PROFILE in $(ls files/valid/profiles/*); do
  assert cat "$PROFILE" | $ANTIMONY edit new_profile --stdin

  SAVED=$(env EDITOR=cat $ANTIMONY edit new_profile)
  assert_eq $? 0
  assert_str "$SAVED" "$(cat $PROFILE)"
done

# Cleanup should also succeed.
assert $ANTIMONY remove new_profile --yes

# Same, but for features
for FEATURE in $(ls files/valid/features/*); do
  assert cat "$FEATURE" | $ANTIMONY edit new_feature --feature --stdin

  SAVED=$(env EDITOR=cat $ANTIMONY edit --feature new_feature)
  assert_eq $? 0
  assert_str "$SAVED" "$(cat $FEATURE)"
done
assert $ANTIMONY remove new_feature --feature --yes

for PROFILE in $(ls files/invalid/profiles/*); do
  assert ! cat "$PROFILE" | $ANTIMONY edit new_profile --stdin
done
# This should now fail, as the profile should not have been added.
assert ! $ANTIMONY remove new_profile --yes

for FEATURE in $(ls files/invalid/features/*); do
  assert ! cat "$FEATURE" | $ANTIMONY edit new_feature --feature --stdin
done
assert ! $ANTIMONY remove new_feature --feature --yes
