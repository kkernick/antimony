-s dir
--name antimony-sandbox
--iteration 1
--license Unlicense
--url "https://github.com/kkernick/antimony"
--description "Sandbox Applications"
--depends bubblewrap
--depends xdg-dbus-proxy

--after-install hooks/after_install.sh
--after-remove hooks/after_remove.sh
--after-upgrade hooks/after_install.sh

./target/x86_64-unknown-linux-gnu/release/antimony=/usr/bin/antimony
./target/x86_64-unknown-linux-gnu/release/antimony-monitor=/usr/share/antimony/utilities/antimony-monitor
./target/x86_64-unknown-linux-gnu/release/antimony-dumper=/usr/share/antimony/utilities/antimony-dumper
./target/x86_64-unknown-linux-gnu/release/antimony-spawn=/usr/share/antimony/utilities/antimony-spawn
./target/x86_64-unknown-linux-gnu/release/antimony-open=/usr/share/antimony/utilities/antimony-open
./target/x86_64-unknown-linux-gnu/release/antimony-tracer=/usr/share/antimony/utilities/antimony-tracer
./target/x86_64-unknown-linux-gnu/release/antimony-lockdown=/usr/share/antimony/utilities/antimony-lockdown
./target/x86_64-unknown-linux-gnu/release/antimony-notify=/usr/share/antimony/utilities/antimony-notify

./config/profiles=/usr/share/antimony/config
./config/features=/usr/share/antimony/config
./config/default.toml=/usr/share/antimony/config/profiles/default.toml

./config/feature.toml=/usr/share/antimony/config/feature.toml
./config/profile.toml=/usr/share/antimony/config/profile.toml
./config/config.d/base.toml=/etc/antimony.d/base.toml

./generated/antimony.bash=/usr/share/bash-completion/completions/antimony
./generated/antimony.fish=/usr/share/fish/vendor_completions.d/antimony.fish
./generated/_antimony=/usr/share/zsh/site-functions/_antimony

./generated/antimony.1.gz=/usr/share/man/man1/antimony.1.gz
./generated/antimony-edit.1.gz=/usr/share/man/man1/antimony-edit.1.gz
./generated/antimony-export.1.gz=/usr/share/man/man1/antimony-export.1.gz
./generated/antimony-help.1.gz=/usr/share/man/man1/antimony-help.1.gz
./generated/antimony-import.1.gz=/usr/share/man/man1/antimony-import.1.gz
./generated/antimony-info.1.gz=/usr/share/man/man1/antimony-info.1.gz
./generated/antimony-integrate.1.gz=/usr/share/man/man1/antimony-integrate.1.gz
./generated/antimony-package.1.gz=/usr/share/man/man1/antimony-package.1.gz
./generated/antimony-refresh.1.gz=/usr/share/man/man1/antimony-refresh.1.gz
./generated/antimony-remove.1.gz=/usr/share/man/man1/antimony-remove.1.gz
./generated/antimony-run.1.gz=/usr/share/man/man1/antimony-run.1.gz



./install/antimony=/etc/apparmor.d/antimony
